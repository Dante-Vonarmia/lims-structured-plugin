      "index": 5,
      "type": "number",
      "normalize": {
        "o_to_0": true,
        "l_to_1": true
      },
      "std_type": "number"
    },
    "nominal_work_pressure_mpa": {
      "label": "公称工作压力MPa",
      "index": 6,
      "type": "number",
      "normalize": {
        "o_to_0": true,
        "l_to_1": true
