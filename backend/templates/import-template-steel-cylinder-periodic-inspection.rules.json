{
  "row_rules": {
    "min_tokens": 6
  },
  "info_fields": [
    {
      "key": "file_no",
      "label": "文件编号"
    },
    {
      "key": "inspect_standard",
      "label": "检验执行标准"
    },
    {
      "key": "record_no",
      "label": "记录编号"
    },
    {
      "key": "submit_org",
      "label": "送检单位"
    }
  ],
  "fields": {
    "inspect_date": {
      "label": "检验日期",
      "index": 0,
      "type": "date",
      "empty_strategy": "carry_forward",
      "std_type": "date"
    },
    "ownership_code": {
      "label": "产权代码编号",
      "index": 1,
      "type": "code",
      "max_len": 12,
      "empty_strategy": "carry_forward",
      "normalize": {
        "trim": true,
        "fullwidth_to_halfwidth": true
      },
      "std_type": "string"
    },
    "filling_medium": {
      "label": "充装介质",
      "index": 2,
      "type": "text",
      "normalize": {
        "trim": true,
        "fullwidth_to_halfwidth": true
      },
      "choices": [
        {
          "label": "Ar"
        },
        {
          "label": "O2"
        },
        {
          "label": "N2"
        },
        {
          "label": "CO2"
        }
      ],
      "std_type": "string"
    },
    "manufacturer_code": {
      "label": "制造单位代码",
